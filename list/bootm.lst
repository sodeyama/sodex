  25              	.global _start,middle_start,print_all_registers
  26              	_start:         
  27              	middle_start:   
  28 0000 8CC8     	        movw    %cs, %ax
  29 0002 8ED8     	        movw    %ax, %ds
  30 0004 8EC0     	        movw    %ax, %es
  31              	
  32              	        # Get the max size of the physical memory,
  33              	        # and we'll set it at 0x90000.
  34 0006 6631C9   	        xorl    %ecx, %ecx
  35 0009 6631D2   	        xorl    %edx, %edx
  36 000c B80090   	        movw    $0x9000, %ax
  37 000f 8EE0     	        movw    %ax, %fs
  38 0011 6631C0   	        xorl    %eax, %eax
  39 0014 6466A300 	        movl    %eax, %fs:(0x0)
  39      00
  40 0019 EB01     	        jmp     pre_e820
  41              	
  42              	/* We have to get the phisical memory map.
  43              	 * Using "Function E820" and "Function E801" but not "Function 88H",
  44              	 * we'll get it.    
  45              	 *  EAX 0xE820 - BIOS command to get the memory map
  46              	 *  EDX "SMAP" - special string to get the memory map
  47              	 *  ES:DI - entry buffer address to set the memory map
  48              	 *  ECX - the size of the entry buffer                                  
  49              	 */
  50 001b 20       	        e820_mmap_maxsize: .byte 32
  51              	SMAP = 0x534d4150 # "SMAP"
  52              	
  53              	pre_e820:               
  54 001c 6631DB   	        xorl    %ebx, %ebx
  55 001f BF6F03   	        movw    $MEMORY_MAP, %di
  56              	
